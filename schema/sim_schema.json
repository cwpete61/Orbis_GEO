{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "title": "Simulation Results Schema",
    "description": "Schema for the output generated by the comparative GEO simulations engine for Orbis Local.",
    "type": "object",
    "properties": {
        "baseline": {
            "type": "object",
            "properties": {
                "brand_name": {
                    "type": "string"
                },
                "is_optimized": {
                    "type": "boolean"
                },
                "grid": {
                    "type": "array",
                    "items": {
                        "type": "object",
                        "properties": {
                            "lat": {
                                "type": "number"
                            },
                            "lng": {
                                "type": "number"
                            },
                            "score": {
                                "type": "number"
                            }
                        },
                        "required": [
                            "lat",
                            "lng",
                            "score"
                        ]
                    }
                },
                "timestamp": {
                    "type": "string",
                    "format": "date-time"
                }
            },
            "required": [
                "brand_name",
                "is_optimized",
                "grid",
                "timestamp"
            ]
        },
        "optimized": {
            "type": "object",
            "properties": {
                "brand_name": {
                    "type": "string"
                },
                "is_optimized": {
                    "type": "boolean"
                },
                "grid": {
                    "type": "array",
                    "items": {
                        "type": "object",
                        "properties": {
                            "lat": {
                                "type": "number"
                            },
                            "lng": {
                                "type": "number"
                            },
                            "score": {
                                "type": "number"
                            }
                        },
                        "required": [
                            "lat",
                            "lng",
                            "score"
                        ]
                    }
                },
                "timestamp": {
                    "type": "string",
                    "format": "date-time"
                }
            },
            "required": [
                "brand_name",
                "is_optimized",
                "grid",
                "timestamp"
            ]
        },
        "comparison": {
            "type": "object",
            "properties": {
                "avg_baseline": {
                    "type": "number"
                },
                "avg_optimized": {
                    "type": "number"
                },
                "delta": {
                    "type": "number"
                }
            },
            "required": [
                "avg_baseline",
                "avg_optimized",
                "delta"
            ]
        }
    },
    "required": [
        "baseline",
        "optimized",
        "comparison"
    ]
}